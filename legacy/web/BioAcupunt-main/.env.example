# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"

# DATABASE_URL: Required for live PostgreSQL database connection (e.g. Supabase, Relational DBMS)
DATABASE_URL="postgresql://postgres:sua-senha-aqui@db.your-supabase-id.supabase.co:5432/postgres?schema=public"

# Supabase Frontend Credentials (Vite and Next.js compatibility)
VITE_SUPABASE_URL="https://myxdfraslkomuokraygh.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_sJupzB6fYqZvrg-7uXTTYQ_hZbWP2Uj"
NEXT_PUBLIC_SUPABASE_URL="https://myxdfraslkomuokraygh.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_sJupzB6fYqZvrg-7uXTTYQ_hZbWP2Uj"

# SUPABASE: Backend Service Role Key (Server-side only)
SUPABASE_SERVICE_ROLE_KEY="sb_secret_your-service-role-key"

# PORT: The port the backend server should bind to (defaults to 3000)
PORT=3000

# NODE_ENV: Execution environment (e.g. development or production)
NODE_ENV="development"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

