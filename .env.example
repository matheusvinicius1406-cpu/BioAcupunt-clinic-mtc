# =============================================================================
# Variaveis de ambiente — BioAcupunt Backend (producao)
# =============================================================================
# Copie este arquivo para `.env` e preencha os valores reais.
# NUNCA comite o `.env` real no repositorio!
#
# Use no dashboard da Vercel: Settings -> Environment Variables
# =============================================================================

# --- Banco de Dados (Neon PostgreSQL) ---
# Obtenha a URL no painel do Neon: https://neon.tech
# Use o formato com asyncpg:
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb

# --- Chaves secretas (gerar com: openssl rand -hex 32) ---
JWT_SECRET_KEY=substitua-por-uma-chave-aleatoria-de-32-caracteres
DOCUMENT_HASH_SECRET=substitua-por-outra-chave-aleatoria

# --- Ambiente ---
ENVIRONMENT=production

# --- CORS (origens permitidas) ---
# Para desenvolvimento mobile, o app Android nao passa por CORS.
# Mas se tiver um frontend web futuro, adicione a URL:
CORS_ORIGINS=["*"]
